{
  "name": "cursor-orchestrator-menu",
  "displayName": "Cursor Orchestrator Menu",
  "description": "Interactive menus (QuickPick) and sidebar tree for the Agentic Coding Flywheel.",
  "version": "0.2.1",
  "publisher": "local",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": ["Other"],
  "activationEvents": [
    "onView:cursorOrchestratorMenu.sidebar",
    "onCommand:cursorOrchestratorMenu.openMenu",
    "onCommand:cursorOrchestratorMenu.orchestrateWizard",
    "onCommand:cursorOrchestratorMenu.runVerify",
    "onCommand:cursorOrchestratorMenu.runPublishGate",
    "onCommand:cursorOrchestratorMenu.showBeads",
    "onCommand:cursorOrchestratorMenu.openPublishingDoc",
    "onCommand:cursorOrchestratorMenu.refreshSidebar",
    "onCommand:cursorOrchestratorMenu.openDoc"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "cursor-orchestrator-hub",
          "title": "Orchestrator",
          "icon": "media/orchestrator.svg"
        }
      ]
    },
    "views": {
      "cursor-orchestrator-hub": [
        {
          "id": "cursorOrchestratorMenu.sidebar",
          "name": "Flywheel",
          "contextualTitle": "Agentic Coding Flywheel"
        }
      ]
    },
    "menus": {
      "view/title": [
        {
          "command": "cursorOrchestratorMenu.refreshSidebar",
          "when": "view == cursorOrchestratorMenu.sidebar",
          "group": "navigation@1"
        }
      ]
    },
    "commands": [
      {
        "command": "cursorOrchestratorMenu.openMenu",
        "title": "Open Orchestrator Menu",
        "category": "Orchestrator"
      },
      {
        "command": "cursorOrchestratorMenu.orchestrateWizard",
        "title": "Orchestrate Wizard (step-by-step)",
        "category": "Orchestrator"
      },
      {
        "command": "cursorOrchestratorMenu.runVerify",
        "title": "Run verify-cursor-orchestrator.mjs",
        "category": "Orchestrator"
      },
      {
        "command": "cursorOrchestratorMenu.runPublishGate",
        "title": "Run publish-gate.mjs",
        "category": "Orchestrator"
      },
      {
        "command": "cursorOrchestratorMenu.showBeads",
        "title": "List beads (br list)",
        "category": "Orchestrator"
      },
      {
        "command": "cursorOrchestratorMenu.openPublishingDoc",
        "title": "Open publishing runbook",
        "category": "Orchestrator"
      },
      {
        "command": "cursorOrchestratorMenu.openDoc",
        "title": "Open markdown doc by path",
        "category": "Orchestrator"
      },
      {
        "command": "cursorOrchestratorMenu.refreshSidebar",
        "title": "Refresh",
        "icon": "$(refresh)",
        "category": "Orchestrator"
      }
    ],
    "keybindings": [
      {
        "command": "cursorOrchestratorMenu.openMenu",
        "key": "ctrl+shift+alt+o",
        "mac": "cmd+shift+alt+o",
        "when": "workspaceFolderCount > 0"
      }
    ],
    "configuration": {
      "title": "Cursor Orchestrator Menu",
      "properties": {
        "cursorOrchestratorMenu.agentChatCommand": {
          "type": "string",
          "default": "",
          "description": "Optional: VS Code command ID to open Cursor Agent chat after copying a prompt (e.g. from Command Palette → Copy Command ID). Leave empty to only use clipboard + notification."
        },
        "cursorOrchestratorMenu.sidebarAutoRefreshSeconds": {
          "type": "number",
          "default": 0,
          "minimum": 0,
          "maximum": 300,
          "description": "Automatically refresh the sidebar tree every N seconds (0 = disabled)."
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "package": "vsce package"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "@types/vscode": "^1.85.0",
    "typescript": "^5.4.0"
  }
}
